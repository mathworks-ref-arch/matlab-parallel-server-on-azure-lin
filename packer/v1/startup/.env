# startup/.env: sourced by bash(1) at launch of the virtual machine in user data
# Collection of environment variables used by startup scripts to configure the cluster
AZURE_IMDS_ENDPOINT="http://169.254.169.254/metadata"
INSTANCE_METADATA=$(curl -s -H Metadata:true --noproxy "*" "${AZURE_IMDS_ENDPOINT}/instance?api-version=2021-02-01")
LOADBALANCER_METADATA=$(curl -s -H Metadata:true --noproxy "*" "${AZURE_IMDS_ENDPOINT}/loadbalancer?api-version=2020-10-01")
MATLAB_ROOT=/usr/local/matlab
MATLAB_RELEASE=$(cat "${MATLAB_ROOT}/VersionInfo.xml" | xq -x '/MathWorks_version_info/release')
MATLAB_SHELL=/bin/bash

MJS_DEF_FILE=${MATLAB_ROOT}/toolbox/parallel/bin/mjs_def.sh
MJS_STATUS_LOG_FILE=/var/log/mathworks/mjs_status_transitions.log
MJS_BUSY_IDLE_SCRIPTS=/opt/mathworks/cluster_management/terminationpolicies/mjs_status_scripts

CLUSTER_MANAGEMENT_DATA_FILE=/opt/mathworks/cluster_management/data/cluster_management_data.json

# Check for Data Disks
DISK_COUNT=$(echo "$INSTANCE_METADATA" | jq -r '.compute.storageProfile.dataDisks | length')

# In the instance metadata JSON, dataDisks is an array. We check if the length is greater than 0.
if [[ "$DISK_COUNT" -gt 0 ]]; then
    CHECKPOINT_ROOT=/data1/mjs
else
    CHECKPOINT_ROOT=/var/lib/mjs
fi
SECURITY_ROOT=${CHECKPOINT_ROOT}/security
SECRET_FILE=${SECURITY_ROOT}/secret
CERT_FILE=${SECURITY_ROOT}/cert
MJS_ADMIN_PASSWORD_FILE=${SECURITY_ROOT}/initial_admin_password

# Parse Network & Compute information from the instance metadata
PRIVATE_IPV4=$(echo "$INSTANCE_METADATA" | jq -r '.network.interface[0].ipv4.ipAddress[0].privateIpAddress')
LOCAL_HOSTNAME=$(echo "$INSTANCE_METADATA" | jq -r '.compute.osProfile.computerName')
SUBSCRIPTION_ID=$(echo "$INSTANCE_METADATA" | jq -r '.compute.subscriptionId')
RESOURCE_ID=$(echo "$INSTANCE_METADATA" | jq -r '.compute.resourceId')
LOCATION=$(echo "$INSTANCE_METADATA" | jq -r '.compute.location')

# Parse Public IP from load balancer data, this is needed for Public IP resources of the Standard SKU
PUBLIC_IPV4=$(echo "$LOADBALANCER_METADATA" | jq -r '.loadbalancer.publicIpAddresses[0].frontendIpAddress')

# *EXTERNAL_HOSTNAME: Hostname for MATLAB clients and headnode or workers connection.
# *INTERNAL_HOSTNAME: Hostname for Worker to Worker communication.
if [[ "${PUBLIC_IPV4}" != "null" ]]; then
    # Scenario 1: Public IP Enabled
    # External: Clients use Azure Public FQDN to reach the cluster over the internet.
    # Internal: Workers use local hostnames (resolvable within Azure VNET) for inter-cluster comms.
    if [[ "${NODE_TYPE}" == "WORKER" ]]; then
        INSTANCE_ID="${RESOURCE_ID##*/}"
        EXTERNAL_HOSTNAME="vm${INSTANCE_ID}.${DOMAIN_NAME_LABEL}.${LOCATION}.cloudapp.azure.com"
    fi
    INTERNAL_HOSTNAME="${LOCAL_HOSTNAME}"

elif [[ -n "${CUSTOM_DNS_SUFFIX}" ]]; then
    # Scenario 2: Private Network with Custom DNS.
    # Use the full Custom FQDN for both client and worker-to-worker traffic.
    FULL_DNS_NAME="${LOCAL_HOSTNAME}.${CUSTOM_DNS_SUFFIX}"
    EXTERNAL_HOSTNAME="${FULL_DNS_NAME}"
    INTERNAL_HOSTNAME="${FULL_DNS_NAME}"
    
else
    # Scenario 3: Private Network (No Custom DNS).
    # External: Peered clients use Private IP (no DNS required).
    # Internal: Workers communicate via Private IP to avoid DNS dependency.
    # Setting hostnames to Private IPs only work for MATLAB R2023a and newer releases
    if [[ "${MATLAB_RELEASE}" > "R2022b" ]]; then
        EXTERNAL_HOSTNAME="${PRIVATE_IPV4}"
        INTERNAL_HOSTNAME="${PRIVATE_IPV4}"
    else
        EXTERNAL_HOSTNAME="${LOCAL_HOSTNAME}"
        INTERNAL_HOSTNAME="${LOCAL_HOSTNAME}"
    fi
fi

# Assign to node-specific variables
if [[ "${NODE_TYPE}" == "WORKER" ]]; then
    WORKER_EXTERNAL_HOSTNAME="${EXTERNAL_HOSTNAME}"
    WORKER_INTERNAL_HOSTNAME="${INTERNAL_HOSTNAME}"
else
    HEADNODE_INTERNAL_HOSTNAME="${INTERNAL_HOSTNAME}"
fi
